# ── RunPod sync configuration ────────────────────────────────────────────
# All four scripts source this file. Edit for your project.

# SSH alias for the pod. set_pod.sh writes a matching Host block to
# ~/.ssh/config, so sync_up / pull_results / run_persona / set_pod all agree.

REMOTE_HOST="local_first_workflow"

# Where your code lives on the pod. /workspace is the default working dir
# in most RunPod templates. The pod is ephemeral — nothing here survives a
# pod stop. Code + data get re-pushed at the start of each day.

REMOTE_DIR="/workspace/"

# >>> PER-PROJECT KNOB <<<  Your repo on disk.
# Default: a sibling of scripts/ named "persona_introspection". Change the
# trailing folder name (or replace the whole expression with an absolute path)
# when you point this workflow at a different project. The path is built
# without resolving the leaf so it works even if the repo isn't checked out
# yet — only the parent of scripts/ has to exist.

LOCAL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/persona_introspection"

# Where your code writes outputs (relative to repo root). pull_results uses
# this to know what to fetch back. Results land in experiments/*/results/
# so we pull the whole experiments/ tree to get all of them.

RESULTS_SUBDIR="experiments"

# The requirements file on the pod (relative to REMOTE_DIR). run_persona.sh
# checks this file exists and hashes it to decide whether to reinstall.
# IMPORTANT: this must be the file INSTALL_CMD below actually installs.

REQUIREMENTS_FILE="remote_requirements.txt"

# How dependencies get installed on the pod. Swap for `uv pip install …`,
# `pip install -e .`, etc. as needed. Keep it pointed at REQUIREMENTS_FILE.

INSTALL_CMD="pip install -r $REQUIREMENTS_FILE"

# >>> PER-PROJECT KNOB <<<  The command that runs your experiment on the pod.
# Args passed to run-persona are appended (printf %q-escaped).
#   run-persona configs/authorship.yaml  ->  python run.py configs/authorship.yaml

RUN_ENTRYPOINT="python run.py"
